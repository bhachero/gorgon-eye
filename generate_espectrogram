@echo off
setlocal enabledelayedexpansion

:: --- CONFIGURACIÓN DE LAYOUT ---
:: OPCIÓN A (Muestreo): Si quieres que se vean GRANDES, pon COLS=15 y ROWS=20 (aprox 300 fotos)
:: OPCIÓN B (Toda la película): Deja COLS=30 y el script calculará las ROWS necesarias hacia abajo.
set "COLS=30"
set "SCALE_SIZE=300"

:: 1. CONTAR Y CALCULAR MUESTREO
set /a "TOTAL=0"
for %%i in (*.jpg) do set /a "TOTAL+=1"

:: Si quieres TODA la película, cambia este "MAX_ALLOWED" al número total (2627)
set /a "MAX_ALLOWED=400"
set /a "SKIP=TOTAL / MAX_ALLOWED"
if %SKIP% LSS 1 set "SKIP=1"

echo [+] Total frames: %TOTAL% ^| Saltando cada %SKIP% fotos.
echo [+] Tamaño de celda: %SCALE_SIZE%px.

:: 2. SELECCIÓN DE IMÁGENES
if exist lista_final.txt del lista_final.txt
set /a "COUNT=0"
set /a "SELECTED=0"

for %%i in (*.jpg) do (
    set /a "MODULO=COUNT %% SKIP"
    if !MODULO! EQU 0 (
        echo file '%%i' >> lista_final.txt
        set /a "SELECTED+=1"
    )
    set /a "COUNT+=1"
)

:: 3. CÁLCULO DE FILAS (Crecimiento vertical)
set /a "ROWS=(%SELECTED% + %COLS% - 1) / %COLS%"

echo [+] Generando layout de %COLS%x%ROWS%...

:: 4. RENDERIZADO PROFESIONAL
:: Usamos 'force_original_aspect_ratio' para que no haya deformación.
ffmpeg -f concat -safe 0 -i lista_final.txt -vf "scale=%SCALE_SIZE%:%SCALE_SIZE%:force_original_aspect_ratio=decrease,pad=%SCALE_SIZE%:%SCALE_SIZE%:(ow-iw)/2:(oh-ih)/2:color=black,tile=%COLS%x%ROWS%:padding=4:margin=15:color=black" -update 1 -frames:v 1 -q:v 1 "espectrograma.jpg"

del lista_final.txt
pause
